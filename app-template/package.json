{
  "name": "nuxt-gsap-luxury-starter",
  "private": true,
  "type": "module",
  "version": "1.0.0",
  "scripts": {
    "build": "nuxt build",
    "dev": "nuxt dev",
    "generate": "nuxt generate",
    "preview": "nuxt preview",
    "postinstall": "nuxt prepare",
    "postbuild": "node -e \"const p=require('./.output/server/package.json');p.main='index.mjs';p.scripts={start:'node index.mjs'};require('fs').writeFileSync('./.output/server/package.json',JSON.stringify(p,null,2))\"",
    "deploy": "npm run build && gcloud run deploy server --source .output/server --region us-central1 --project industry-examples --allow-unauthenticated && firebase deploy --only hosting"
  },
  "dependencies": {
    "@nuxtjs/tailwindcss": "^6.14.0",
    "@pinia/nuxt": "^0.11.3",
    "@vueuse/core": "^14.1.0",
    "firebase": "^10.8.0",
    "firebase-admin": "latest",
    "firebase-functions": "latest",
    "gsap": "^3.12.5",
    "lenis": "^1.0.42",
    "lucide-vue-next": "^0.344.0",
    "nuxt": "^3.10.3",
    "pinia": "^3.0.4",
    "split-type": "^0.3.4",
    "vue": "^3.4.21",
    "vue-router": "^4.3.0"
  }
}
